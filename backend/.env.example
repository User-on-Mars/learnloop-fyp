PORT=4000
CLIENT_URL=http://localhost:5173
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>/<db>?retryWrites=true&w=majority
JWT_SECRET=change_me_to_a_long_random_string

# Firebase Configuration (for email verification)
# Email verification is handled by Firebase Authentication
# Make sure to enable Email/Password provider in Firebase Console
FIREBASE_PROJECT_ID=your-project-id
# Optional: Full service account key JSON for production token verification
# Generate from Firebase Console > Project Settings > Service Accounts > Generate New Private Key
# Paste the entire JSON as a single line:
# FIREBASE_SERVICE_ACCOUNT_KEY={"type":"service_account","project_id":"...","private_key":"...",...}

# Redis Cache Configuration
REDIS_URL=redis://localhost:6379

# Optional SMTP (for real password reset emails)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=LearnLoop <no-reply@learnloop.local>

# eSewa Payment Gateway
# For testing: use defaults below (EPAYTEST credentials)
# For production: set ESEWA_ENV=production and use your merchant credentials
ESEWA_ENV=test
ESEWA_PRODUCT_CODE=EPAYTEST
ESEWA_SECRET_KEY=8gBm/:&EnhH.1/q
ESEWA_SUCCESS_URL=http://localhost:5173/subscription/esewa/success
ESEWA_FAILURE_URL=http://localhost:5173/subscription/esewa/failure

# Stripe Checkout (one-time test payments)
# Put real values in backend/.env locally and Render environment variables in deployment.
STRIPE_SECRET_KEY=sk_test_your_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here
STRIPE_CURRENCY=npr
STRIPE_SUCCESS_URL=http://localhost:5173/subscription/stripe/success?session_id={CHECKOUT_SESSION_ID}
STRIPE_CANCEL_URL=http://localhost:5173/subscription
