{
  "info": {
    "name": "LearnLoop API Tests - FYP",
    "description": "Complete API test suite for LearnLoop Final Year Project",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:4000",
      "type": "string"
    },
    {
      "key": "token",
      "value": "",
      "type": "string"
    },
    {
      "key": "admin_token",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "00 Health Check",
      "item": [
        {
          "name": "API Health",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/health",
              "host": ["{{base_url}}"],
              "path": ["api", "health"]
            },
            "description": "Check if API is running"
          },
          "response": []
        }
      ]
    },
    {
      "name": "01 Authentication",
      "item": [
        {
          "name": "1.1 User Signup (Success)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"testuser@example.com\",\n  \"password\": \"Test123!@#\",\n  \"displayName\": \"Test User\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{base_url}}/api/auth/signup",
              "host": ["{{base_url}}"],
              "path": ["api", "auth", "signup"]
            },
            "description": "Create a new user account"
          },
          "response": []
        },
        {
          "name": "1.2 User Login (Success)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    var jsonData = pm.response.json();",
                  "    pm.collectionVariables.set('token', jsonData.token);",
                  "    console.log('Token saved:', jsonData.token);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"testuser@example.com\",\n  \"password\": \"Test123!@#\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{base_url}}/api/auth/login",
              "host": ["{{base_url}}"],
              "path": ["api", "auth", "login"]
            },
            "description": "Login and get JWT token (automatically saved)"
          },
          "response": []
        },
        {
          "name": "1.3 Login Invalid Credentials (Failure)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"testuser@example.com\",\n  \"password\": \"WrongPassword123\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{base_url}}/api/auth/login",
              "host": ["{{base_url}}"],
              "path": ["api", "auth", "login"]
            },
            "description": "Test authentication failure with wrong password"
          },
          "response": []
        }
      ]
    },
    {
      "name": "02 Authorization Tests",
      "item": [
        {
          "name": "2.1 Get Skills (No Token - Should Fail)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/skills",
              "host": ["{{base_url}}"],
              "path": ["api", "skills"]
            },
            "description": "Test protected route without authentication"
          },
          "response": []
        },
        {
          "name": "2.2 Get Skills (With Token - Should Succeed)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/skills",
              "host": ["{{base_url}}"],
              "path": ["api", "skills"]
            },
            "description": "Test protected route with valid token"
          },
          "response": []
        }
      ]
    },
    {
      "name": "03 Skill Maps",
      "item": [
        {
          "name": "3.1 Create Skill Map (Valid)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"React Mastery\",\n  \"nodeCount\": 8\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{base_url}}/api/skills",
              "host": ["{{base_url}}"],
              "path": ["api", "skills"]
            },
            "description": "Create a new skill map with 8 nodes"
          },
          "response": []
        },
        {
          "name": "3.2 Create Skill Map (Invalid - Empty Name)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"\",\n  \"nodeCount\": 8\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{base_url}}/api/skills",
              "host": ["{{base_url}}"],
              "path": ["api", "skills"]
            },
            "description": "Test validation - empty name should fail"
          },
          "response": []
        },
        {
          "name": "3.3 Create Skill Map (Invalid - Too Many Nodes)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Test Skill\",\n  \"nodeCount\": 20\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{base_url}}/api/skills",
              "host": ["{{base_url}}"],
              "path": ["api", "skills"]
            },
            "description": "Test validation - max 16 nodes allowed"
          },
          "response": []
        }
      ]
    },
    {
      "name": "04 Admin Routes",
      "item": [
        {
          "name": "4.1 Admin Verify (Regular User - Should Fail)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/admin/verify",
              "host": ["{{base_url}}"],
              "path": ["api", "admin", "verify"]
            },
            "description": "Test admin route protection - regular user should be denied"
          },
          "response": []
        },
        {
          "name": "4.2 Admin Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    var jsonData = pm.response.json();",
                  "    pm.collectionVariables.set('admin_token', jsonData.token);",
                  "    console.log('Admin token saved');",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@learnloop.com\",\n  \"password\": \"Admin123!@#\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{base_url}}/api/auth/login",
              "host": ["{{base_url}}"],
              "path": ["api", "auth", "login"]
            },
            "description": "Login as admin (run seedAdmin.js first)"
          },
          "response": []
        },
        {
          "name": "4.3 Admin Verify (Admin User - Should Succeed)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{admin_token}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/admin/verify",
              "host": ["{{base_url}}"],
              "path": ["api", "admin", "verify"]
            },
            "description": "Test admin access with admin token"
          },
          "response": []
        }
      ]
    },
    {
      "name": "05 Rate Limiting",
      "item": [
        {
          "name": "5.1 Multiple Login Attempts",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"testuser@example.com\",\n  \"password\": \"WrongPassword\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{base_url}}/api/auth/login",
              "host": ["{{base_url}}"],
              "path": ["api", "auth", "login"]
            },
            "description": "Run this multiple times to test rate limiting (should block after 5 attempts)"
          },
          "response": []
        }
      ]
    }
  ]
}
