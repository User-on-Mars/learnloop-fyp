{
  "info": {
    "name": "LearnLoop API Tests",
    "description": "API testing collection for LearnLoop FYP",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:4000",
      "type": "string"
    },
    {
      "key": "firebase_token",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "01 - Health Check",
      "item": [
        {
          "name": "API Health Check",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/health",
              "host": ["{{base_url}}"],
              "path": ["api", "health"]
            }
          }
        }
      ]
    },
    {
      "name": "02 - User XP Profile",
      "item": [
        {
          "name": "Get XP Profile",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{firebase_token}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/xp/profile",
              "host": ["{{base_url}}"],
              "path": ["api", "xp", "profile"]
            }
          }
        }
      ]
    },
    {
      "name": "03 - Invitations",
      "item": [
        {
          "name": "Get My Invitations",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{firebase_token}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/invitations",
              "host": ["{{base_url}}"],
              "path": ["api", "invitations"]
            }
          }
        }
      ]
    },
    {
      "name": "04 - Notifications",
      "item": [
        {
          "name": "Get Notifications",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{firebase_token}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/notifications?limit=50",
              "host": ["{{base_url}}"],
              "path": ["api", "notifications"],
              "query": [
                {
                  "key": "limit",
                  "value": "50"
                }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "05 - Skills",
      "item": [
        {
          "name": "Get All Skills",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{firebase_token}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/skills",
              "host": ["{{base_url}}"],
              "path": ["api", "skills"]
            }
          }
        }
      ]
    },
    {
      "name": "06 - Rooms",
      "item": [
        {
          "name": "Get My Rooms",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{firebase_token}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/rooms",
              "host": ["{{base_url}}"],
              "path": ["api", "rooms"]
            }
          }
        }
      ]
    },
    {
      "name": "07 - Leaderboard",
      "item": [
        {
          "name": "Get Weekly Leaderboard",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{firebase_token}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/leaderboard/weekly?page=1&limit=10",
              "host": ["{{base_url}}"],
              "path": ["api", "leaderboard", "weekly"],
              "query": [
                {
                  "key": "page",
                  "value": "1"
                },
                {
                  "key": "limit",
                  "value": "10"
                }
              ]
            }
          }
        },
        {
          "name": "Get My Ranks",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{firebase_token}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/leaderboard/my-ranks",
              "host": ["{{base_url}}"],
              "path": ["api", "leaderboard", "my-ranks"]
            }
          }
        }
      ]
    }
  ]
}
